{
  "name": "glyph-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node server/server.mjs & vite --config app/vite.config.ts; kill %1",
    "server": "node server/server.mjs",
