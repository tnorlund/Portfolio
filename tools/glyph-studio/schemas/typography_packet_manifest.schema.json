{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "typography_packet_manifest.schema.json",
  "title": "Typography line-crop packet manifest",
  "type": "object",
  "required": ["manifest_version", "params", "content_hash", "n_packets", "packets"],
  "properties": {
    "manifest_version": {"const": "tp-1"},
    "params": {
      "type": "object",
      "required": ["receipts", "max_lines", "min_letters", "max_overlaps", "contamination_max", "table", "merchants"],
      "properties": {
        "receipts": {"type": "integer", "minimum": 0},
        "max_lines": {"type": "integer", "minimum": 0},
        "min_letters": {"type": "integer", "minimum": 0},
        "max_overlaps": {"type": "integer", "minimum": 0},
        "contamination_max": {"type": "number", "minimum": 0, "maximum": 1},
        "table": {"type": "string", "minLength": 1},
        "merchants": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": false
    },
    "content_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "n_packets": {"type": "integer", "minimum": 0},
    "packets": {
      "type": "array",
      "items": {"$ref": "#/$defs/packet"}
    }
  },
  "$defs": {
    "packet": {
      "type": "object",
      "required": ["packet_id", "image_id", "receipt_id", "line_index", "line_ids", "merchant", "slug", "text", "features", "receipt_context", "crops"],
      "properties": {
        "packet_id": {
          "type": "string",
          "pattern": "^[0-9a-f-]{36}_[0-9]+_L[0-9]{3,}$"
        },
        "image_id": {"type": "string", "minLength": 1},
        "receipt_id": {"type": "integer"},
        "line_index": {"type": "integer", "minimum": 0},
        "line_ids": {
          "type": "array",
          "items": {"type": "integer"}
        },
        "merchant": {"type": "string", "minLength": 1},
        "slug": {"type": "string", "minLength": 1},
        "text": {"type": "string"},
        "features": {
          "type": "object",
          "required": ["cap_px", "stroke_med", "density_med", "n_letters", "contamination", "underline", "reverse_video", "slant_deg", "tier"],
          "properties": {
            "cap_px": {"type": ["number", "null"]},
            "stroke_med": {"type": ["number", "null"]},
            "density_med": {"type": ["number", "null"]},
            "n_letters": {"type": "integer", "minimum": 0},
            "contamination": {"type": "number", "minimum": 0, "maximum": 1},
            "underline": {"type": "boolean"},
            "reverse_video": {"type": "integer", "enum": [0, 1]},
            "slant_deg": {
              "type": ["number", "null"],
              "minimum": -45,
              "maximum": 45
            },
            "tier": {"type": "string", "enum": ["normal", "bold", "large"]}
          },
          "additionalProperties": false
        },
        "receipt_context": {
          "type": "object",
          "required": ["body_cap_px", "body_stroke_px", "image_size", "ocr_overlap_score"],
          "properties": {
            "body_cap_px": {"type": ["number", "null"]},
            "body_stroke_px": {"type": ["number", "null"]},
            "image_size": {
              "type": "array",
              "prefixItems": [
                {"type": "integer", "minimum": 1},
                {"type": "integer", "minimum": 1}
              ],
              "minItems": 2,
              "maxItems": 2
            },
            "ocr_overlap_score": {"type": "integer", "minimum": 0}
          },
          "additionalProperties": false
        },
        "crops": {
          "type": "object",
          "required": ["line", "letters"],
          "properties": {
            "line": {"$ref": "#/$defs/crop"},
            "letters": {
              "type": "array",
              "minItems": 1,
              "items": {"$ref": "#/$defs/letterCrop"}
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "crop": {
      "type": "object",
      "required": ["path", "sha256", "width", "height"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^packets/[0-9a-f-]{36}_[0-9]+_L[0-9]{3,}/line\\.png$"
        },
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "letterCrop": {
      "type": "object",
      "required": ["seq", "char", "line_id", "path", "sha256", "width", "height"],
      "properties": {
        "seq": {"type": "integer", "minimum": 0},
        "char": {"type": "string", "minLength": 1, "maxLength": 1},
        "line_id": {"type": "integer"},
        "path": {
          "type": "string",
          "pattern": "^packets/[0-9a-f-]{36}_[0-9]+_L[0-9]{3,}/letters/[0-9]{3,}_u[0-9a-f]{4,}\\.png$"
        },
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
