{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "typography_judge_input.schema.json",
  "title": "Typography blind judge input",
  "type": "object",
  "required": ["schema_version", "packet_id", "line_text", "line_crop", "letter_crops", "context"],
  "properties": {
    "schema_version": {"const": "tj-in-1"},
    "packet_id": {
      "type": "string",
      "pattern": "^[0-9a-f-]{36}_[0-9]+_L[0-9]{3,}$"
    },
    "line_text": {"type": "string"},
    "line_crop": {"$ref": "#/$defs/crop"},
    "letter_crops": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/letterCrop"}
    },
    "context": {
      "type": "object",
      "required": ["cap_px", "stroke_med", "receipt_body_cap_px", "receipt_body_stroke_px"],
      "properties": {
        "cap_px": {"type": ["number", "null"]},
        "stroke_med": {"type": ["number", "null"]},
        "receipt_body_cap_px": {"type": ["number", "null"]},
        "receipt_body_stroke_px": {"type": ["number", "null"]}
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "crop": {
      "type": "object",
      "required": ["path", "sha256", "width", "height"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^packets/[0-9a-f-]{36}_[0-9]+_L[0-9]{3,}/line\\.png$"
        },
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "letterCrop": {
      "type": "object",
      "required": ["seq", "char", "path", "sha256", "width", "height"],
      "properties": {
        "seq": {"type": "integer", "minimum": 0},
        "char": {"type": "string", "minLength": 1, "maxLength": 1},
        "path": {
          "type": "string",
          "pattern": "^packets/[0-9a-f-]{36}_[0-9]+_L[0-9]{3,}/letters/[0-9]{3,}_u[0-9a-f]{4,}\\.png$"
        },
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
